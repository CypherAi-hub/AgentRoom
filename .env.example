# Supabase — required for /login, /signup, middleware, billing.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Stripe — billing checkout + webhook
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Anthropic — sandbox computer-use agent
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional safety caps for the dev sandbox agent loop
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_AGENT_ITERATIONS=20
ANTHROPIC_MAX_AGENT_RUNTIME_MS=300000

# E2B — sandboxed cloud desktop
E2B_API_KEY=e2b_xxx

# Public app URL used for Stripe checkout success/cancel redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Read-only hybrid integration mode. Keep real values in .env.local only.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPOS=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_IDS=
